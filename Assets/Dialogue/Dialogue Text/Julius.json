{
    "dialogueLines": [
        {
            "dialogueID": "1_start",
            "dialogueText": "What do you want, kid? Scram!",
            "emotion": 0,
            "nextDialogueID": ""
        },


        {
            "dialogueID": "2_start",
            "dialogueText": "I heard you beat that old drunk Drover.",
            "emotion": 0,
            "nextDialogueID": "2_next"
        },
        {
            "dialogueID": "2_next",
            "dialogueText": "You think you can just waltz in here and challenge us old-timers?",
            "emotion": 0,
            "nextDialogueID": "2_fight"
        }, {
            "dialogueID": "2_fight",
            "dialogueText": "Just 'cause I'm old doesn't mean I can't fend off you young up-and-comers.",
            "emotion": 0,
            "nextDialogueID": ""
        },

        


        {
            "dialogueID": "3_start",
            "dialogueText": "… Huh not too bad whippersnapper…. You really put up your dukes and worked me out…",
            "emotion": 0,
            "nextDialogueID": "3_next"
        },
        {
            "dialogueID": "3_next",
            "dialogueText": "... if only I could’ve worked out that marriage of mine…my loss probably won’t help things…",
            "emotion": 0,
            "nextDialogueID": "3_end"
        },
        {
            "dialogueID": "3_end",
            "dialogueText": "...care to ignore my silly old murder attempt and play matchmaker for me sonny?",
            "emotion": 0,
            "nextDialogueID": "3_again"
        },
        {
            "dialogueID": "3_again",
            "dialogueText": "If not... we can go again?",
            "emotion": 0,
            "nextDialogueID": ""
        },

        {
            "dialogueID": "6_start",
            "dialogueText": "Ha! Didn't think I'd live to see the day she got dethroned.",
            "emotion": 0,
            "nextDialogueID": "6_next"
        }, {
            "dialogueID": "6_next",
            "dialogueText": "Surprised you're letting her stick around.",
            "emotion": 0,
            "nextDialogueID": "6_end"
        }, {
            "dialogueID": "6_end",
            "dialogueText": "Anyways, how about you and I have a little rematch?",
            "emotion": 0,
            "nextDialogueID": ""
        }
    ]
}
