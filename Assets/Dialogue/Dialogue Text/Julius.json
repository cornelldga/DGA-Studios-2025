        {
            "dialogueID": "1_start",
            "dialogueText": "What do you want, kid? Scram!",
            "emotion": 0,
            "nextDialogueID": ""
        },


        {
            "dialogueID": "2_start",
            "dialogueText": "I heard you beat that old drunk Drover.",
            "emotion": 0,
            "nextDialogueID": "2_next"
        },
        {
            "dialogueID": "2_next",
            "dialogueText": "You think you can just waltz in here and challenge us old-timers?",
            "emotion": 0,
            "nextDialogueID": "2_fight"
        }, {
            "dialogueID": "2_fight",
            "dialogueText": "Just 'cause I'm old doesn't mean I can't fend off you young up-and-comers.",
            "emotion": 0,
            "nextDialogueID": ""
        },

        


        {
            "dialogueID": "3_start",
            "dialogueText": "You got more spirit than I gave you credit for, kid.",
            "emotion": 0,
            "nextDialogueID": "3_next"
        },
        {
            "dialogueID": "3_next",
            "dialogueText": "Maybe I can learn a thing or two from you.",
            "emotion": 0,
            "nextDialogueID": "3_end"
        }, {
            "dialogueID": "3_end",
            "dialogueText": "If you're willing, that is.",
            "emotion": 0,
            "nextDialogueID": ""
        },

        {
            "dialogueID": "6_start",
            "dialogueText": "Ha! Didn't think I'd live to see the day she got dethroned.",
            "emotion": 0,
            "nextDialogueID": "6_next"
        }, {
            "dialogueID": "6_next",
            "dialogueText": "Surprised you're letting her stick around.",
            "emotion": 0,
            "nextDialogueID": "6_end"
        }, {
            "dialogueID": "6_end",
            "dialogueText": "Anyways, how about you and I have a little rematch?",
