{
    "dialogueLines": [
        {
            "dialogueID": "1_start",
            "dialogueText": "Hey! Watch it, buddy! You almost knocked over Granny's favorite plant!",
            "emotion": 0,
            "nextDialogueID": "1_next"
        },
        {
            "dialogueID": "1_next",
            "dialogueText": "What a nuisance.",
            "emotion": 0,
            "nextDialogueID": ""
        },

        {
            "dialogueID": "2_start",
            "dialogueText": "I better not hear that you hurt any of the pigs.",
            "emotion": 0,
            "nextDialogueID": ""
        },

        {
            "dialogueID": "3_start",
            "dialogueText": "So you're just beating on the elderly now?",
            "emotion": 0,
            "nextDialogueID": ""
        },

        
        {
            "dialogueID": "4_start",
            "dialogueText": "Hey! Why are you going around causing problems?",
            "emotion": 0,
            "nextDialogueID": "4_next"
        }, {
            "dialogueID": "4_next",
            "dialogueText": "Starting fights and causing a mess.",
            "emotion": 0,
            "nextDialogueID": "4_fight"
        }, {
            "dialogueID": "4_fight",
            "dialogueText": "I oughta kick you out of this town once and for all.",
            "emotion": 0,
            "nextDialogueID": ""
        },
    

        {
            "dialogueID": "5_start",
            "dialogueText": "Geez… you are one hell of an opponent … they usually leave fights with me in a body bag…",
            "emotion": 0,
            "nextDialogueID": "5_next"
        },
        {
            "dialogueID": "5_next",
            "dialogueText": "... Huff .. what? … you’re taking on my grandmammy? You know what, go for it!",
            "emotion": 0,
            "nextDialogueID": "5_fight"
        },
        {
            "dialogueID": "5_fight",
            "dialogueText": "...COUGH.. Love her, but … huff… she sometimes needs a kick in the hams…",
            "emotion": 0,
            "nextDialogueID": "5_again"
        },
        {
            "dialogueID": "5_again",
            "dialogueText": "I can help you out with that! Would you like to train?",
            "emotion": 0,
            "nextDialogueID": ""
        },

        {
            "dialogueID": "6_start",
            "dialogueText": "You spared her. Thank you.",
            "emotion": 0,
            "nextDialogueID": "6_next"
        }, {
            "dialogueID": "6_next",
            "dialogueText": "I misjudged you before. You're a good man.",
            "emotion": 0,
            "nextDialogueID": "6_fight"
        }, {
            "dialogueID": "6_fight",
            "dialogueText": "Thank you again. I'm happy to train with you anytime.",
            "emotion": 0,
            "nextDialogueID": ""
        }
    ]
}
