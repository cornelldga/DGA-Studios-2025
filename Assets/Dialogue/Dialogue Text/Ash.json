{
    "dialogueLines": [
        {
            "dialogueID": "1_start",
            "dialogueText": "Hey! Watch it, buddy! You almost knocked over Granny's favorite plant!",
            "emotion": 0,
            "nextDialogueID": "1_next"
        },
        {
            "dialogueID": "1_next",
            "dialogueText": "What a nuisance.",
            "emotion": 0,
            "nextDialogueID": ""
        },

        {
            "dialogueID": "2_start",
            "dialogueText": "I better not hear that you hurt any of the pigs.",
            "emotion": 0,
            "nextDialogueID": ""
        },

        {
            "dialogueID": "3_start",
            "dialogueText": "So you're just beating on the elderly now?",
            "emotion": 0,
            "nextDialogueID": ""
        },

        
        {
            "dialogueID": "4_start",
            "dialogueText": "Hey! Why are you going around causing problems?",
            "emotion": 0,
            "nextDialogueID": "4_next"
        }, {
            "dialogueID": "4_next",
            "dialogueText": "Starting fights and causing a mess.",
            "emotion": 0,
            "nextDialogueID": "4_fight"
        }, {
            "dialogueID": "4_fight",
            "dialogueText": "I oughta kick you out of this town once and for all.",
            "emotion": 0,
            "nextDialogueID": ""
        },
    

        {
            "dialogueID": "5_start",
            "dialogueText": "Duke, right? I know I'm in no position to ask for anything, but Granny's all I have.",
            "emotion": 0,
            "nextDialogueID": "5_next"
        }, {
            "dialogueID": "5_next",
            "dialogueText": "She's a ruthless businesswoman, yes. But she's a good lady at heart. Deep down.",
            "emotion": 0,
            "nextDialogueID": "5_fight"
        }, {
            "dialogueID": "5_fight",
            "dialogueText": "I'll even help you train, just promise to spare her.",
            "emotion": 0,
            "nextDialogueID": ""
        },

        {
            "dialogueID": "6_start",
            "dialogueText": "You spared her. Thank you.",
            "emotion": 0,
            "nextDialogueID": "6_next"
        }, {
            "dialogueID": "6_next",
            "dialogueText": "I misjudged you before. You're a good man.",
            "emotion": 0,
            "nextDialogueID": "6_fight"
        }, {
            "dialogueID": "6_fight",
            "dialogueText": "Thank you again. I'm happy to train with you anytime.",
            "emotion": 0,
            "nextDialogueID": ""
        }
    ]
}
