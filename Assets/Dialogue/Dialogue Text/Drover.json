        },

        {
            "dialogueID": "6_start",
            "dialogueText": "You beat the old hag, huh? She was getting on my nerves.",
            "emotion": 0,
            "nextDialogueID": "6_next"
        }, {
            "dialogueID": "6_next",
            "dialogueText": "But you and me, we're buddies now, right?",
