{
    "dialogueLines": [
        {
            "dialogueID": "1_start",
            "dialogueText": "So you're the bar owner, eh? What's it called—Hero's Haven or something?",
            "emotion": 0,
            "nextDialogueID": "1_next"
        }, {
            "dialogueID": "1_next",
            "dialogueText": "It's a nice place and all, but I ain't gonna let you take our customers. She'll throw another fit.",
            "emotion": 0,
            "nextDialogueID": "1_fight"
        }, {
            "dialogueID": "1_fight",
            "dialogueText": "So what's it gonna be, lad? We gonna hash it out?",
            "emotion": 0,
            "nextDialogueID": ""
        },


        {
            "dialogueID": "2_start",
            "dialogueText": "You got me, lad. My pigs and I are too hammered for this.",
            "emotion": 0,
            "nextDialogueID": "2_next"
        }, {
            "dialogueID": "2_next",
            "dialogueText": "But you gotta admit I can take a punch, eh?",
            "emotion": 0,
            "nextDialogueID": "2_end"
        }, {
            "dialogueID": "2_end",
            "dialogueText": "Wanna go again?",
            "emotion": 0,
